--הפונקציה ניגשת לטבלת הרכבים ובודקת האם מספר הנוסעים בנסיעה עולה על קיבולת הרכב
CREATE OR REPLACE FUNCTION check_vehicle_capacity()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
DECLARE
    v_capacity INT;
BEGIN

    -- שליפת קיבולת הרכב
    SELECT Capacity
    INTO v_capacity
    FROM Vehicle
    WHERE VehicleID = NEW.VehicleID;

    -- בדיקה שהרכב קיים
    IF v_capacity IS NULL THEN
        RAISE EXCEPTION
        'Vehicle % does not exist',
        NEW.VehicleID;
    END IF;

    -- בדיקה שמספר הנוסעים לא עולה על הקיבולת
    IF NEW.NumOfPassengers > v_capacity THEN
        RAISE EXCEPTION
        'Cannot assign % passengers to vehicle %. Maximum capacity is %',
        NEW.NumOfPassengers,
        NEW.VehicleID,
        v_capacity;
    END IF;

    RETURN NEW;

EXCEPTION
    WHEN OTHERS THEN
        RAISE NOTICE 'Error in check_vehicle_capacity: %', SQLERRM;
        RAISE;
END;
$$;

CREATE TRIGGER trg_check_vehicle_capacity
BEFORE INSERT OR UPDATE
ON Trip
FOR EACH ROW
EXECUTE FUNCTION check_vehicle_capacity();

