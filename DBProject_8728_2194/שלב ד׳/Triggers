-- הפונקציה ניגשת לטבלת הביטוחים ובודקת האם קיימת לרכב פוליסה בתוקף בתאריך הנסיעה
CREATE OR REPLACE FUNCTION public.check_vehicle_has_valid_insurance()
RETURNS TRIGGER
LANGUAGE plpgsql
AS $$
DECLARE
    v_valid_insurance_count INT;
BEGIN
    -- בדיקה חלקה: המרה בטוחה של ה-Timestamp ל-Date באמצעות ::date
    SELECT COUNT(*)
    INTO v_valid_insurance_count
    FROM public.insurance i
    WHERE i.vehicleid = NEW.vehicleid
      AND NEW.departuretime::date BETWEEN i.startdate AND i.enddate;

    -- אם לא נמצאה פוליסה בתוקף
    IF v_valid_insurance_count = 0 THEN
        RAISE EXCEPTION
        'Cannot assign vehicle % to trip %. Vehicle has no valid insurance on %',
        NEW.vehicleid,
        NEW.tripid,
        NEW.departuretime::date;
    END IF;

    RETURN NEW;
END;
$$;

DROP TRIGGER IF EXISTS trg_check_vehicle_has_valid_insurance ON public.trip;

CREATE TRIGGER trg_check_vehicle_has_valid_insurance
BEFORE INSERT OR UPDATE OF vehicleid, departuretime
ON public.trip
FOR EACH ROW
EXECUTE FUNCTION public.check_vehicle_has_valid_insurance();

