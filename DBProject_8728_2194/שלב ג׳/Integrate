    platenumber VARCHAR(20),
    model VARCHAR(50),
    capacity INTEGER,
    carcolor VARCHAR(30),
    year INTEGER,
    status VARCHAR(20)
);

-- (כאן תבצע את ה-IMPORT של ה-CSV לטבלה temp_vehicle_import)

-- 2. הכנסת הנתונים לטבלה הסופית vehicle1
INSERT INTO vehicle1 (
    vehicleid, 
    licenseplate, 
    vehicletype, 
    capacity, 
    manufacturer, 
    year, 
    model, 
    carcolor
)
SELECT 
    (SELECT COALESCE(MAX(v.vehicleid), 0) FROM public.vehicle1 v) + ROW_NUMBER() OVER (),
    regexp_replace(t.platenumber, '[^0-9]', '', 'g')::integer,
    -- שימוש באחד הערכים המורשים על פי ה-CHECK CONSTRAINT
    (ARRAY['Bus', 'Minibus', 'Van', 'Taxi'])[floor(random() * 4 + 1)],
    t.capacity,
    split_part(t.model, ' ', 1), 
    t.year,
    t.model,
    t.carcolor
FROM temp_vehicle_import t

