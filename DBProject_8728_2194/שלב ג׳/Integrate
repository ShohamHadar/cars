    id TEXT,
    origin TEXT,
    destination TEXT
);
-- דוגמה לשינוי ה-Constraint (זה ידרוס את הקיים):
ALTER TABLE public.trip DROP CONSTRAINT chk_trip_status;
ALTER TABLE public.trip ADD CONSTRAINT chk_trip_status 
CHECK (status IN ('Planned', 'Completed', 'Cancelled', 'Pending')); -- הוסף כאן את 'Pending'

INSERT INTO trip (
    tripid, departurelocation, destination, departuretime, status, 
    driverid, vehicleid, price, numofpassengers, durationhours, 
    customer_id, route_origin, route_destination
)
SELECT 
    20521 + ROW_NUMBER() OVER (),
    LEFT(COALESCE(t.origin, 'Unknown'), 20),
    LEFT(COALESCE(t.destination, 'Unknown'), 20),
    (t.orderdate::date + t.starttime::time)::timestamp,
    COALESCE(t.status, 'Planned'),
    d.driverid, -- לא יהיה NULL כי ב-INNER JOIN השורה תיזרק אם אין נהג
    v.vehicleid, -- לא יהיה NULL כי ב-INNER JOIN השורה תיזרק אם אין רכב
    100.00,
    1,
    1.00,
    COALESCE(t.id::integer, 0),
    LEFT(COALESCE(t.origin, 'Unknown'), 100),
    LEFT(COALESCE(t.destination, 'Unknown'), 100)
FROM temp_ride_import t
INNER JOIN public.driver1 d ON t.licensenumber::text = d.licensenumber::text
INNER JOIN public.vehicle1 v ON regexp_replace(t.platenumber, '[^0-9]', '', 'g')::bigint = v.licenseplate
WHERE NOT EXISTS (
    SELECT 1 FROM public.trip tr 
    WHERE tr.customer_id = t.id::integer
);
