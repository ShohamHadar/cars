-- שינוי שם טבלת הרכבים 
ALTER TABLE vehicle RENAME TO vehicle1;

-- שינוי שם טבלת הנהגים 
ALTER TABLE driver RENAME TO driver1;

-- שינוי שם טבלת התחזוקה 
ALTER TABLE maintenance RENAME TO maintenance1;

-- יצירת טבלת לקוחות 
CREATE TABLE customer (
    id INT PRIMARY KEY,
    fullname VARCHAR(100) NOT NULL,
    email VARCHAR(100),
    phonenumber VARCHAR(20)
);

-- יצירת טבלת מסלולים 
CREATE TABLE route (
    origin VARCHAR(100),
    destination VARCHAR(100),
    distancekm INT,
    estimatedtraveltime INT,
    PRIMARY KEY (origin, destination)
);

-- הרחבת טבלת הרכבים
ALTER TABLE vehicle1 
ADD COLUMN IF NOT EXISTS model VARCHAR(50),
ADD COLUMN IF NOT EXISTS carcolor VARCHAR(30),
ADD COLUMN IF NOT EXISTS capacity INT;

-- הרחבת טבלת הנסיעות
ALTER TABLE trip 
ADD COLUMN IF NOT EXISTS customer_id INT,
ADD COLUMN IF NOT EXISTS route_origin VARCHAR(100),
ADD COLUMN IF NOT EXISTS route_destination VARCHAR(100);

-- 3. הגדרת קשרי מפתח זר (Foreign Keys) מתוך טבלת ה-trip שלכן אל הטבלאות החדשות שלהן
-- (זה יעבוד רק אחרי שהגיבוי שלהן כבר בפנים, כיcustomer ו-route חייבות להיות קיימות)
ALTER TABLE trip
ADD CONSTRAINT fk_trip_customer FOREIGN KEY (customer_id) REFERENCES customer(id),
ADD CONSTRAINT fk_trip_route FOREIGN KEY (route_origin, route_destination) REFERENCES route(origin, destination);


