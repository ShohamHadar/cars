-- 1. יצירת טבלה זמנית שתחזיק את המידע הגולמי מהטבלה הישנה (maintenance)
CREATE TABLE temp_maintenance_import (
    maintenancedate DATE,
    maintenancetype VARCHAR(50),
    cost INTEGER,
    description VARCHAR(255),
    platenumber VARCHAR(20)
);

-- (כאן תבצעו את ה-Import לקובץ ה-CSV של טבלת ה-maintenance לתוך temp_maintenance_import)

-- 2. העברת הנתונים ל-maintenance1 עם ביצוע JOIN כדי לשייך ל-vehicleid הנכון
INSERT INTO maintenance1 (
    maintenanceid,
    maintenancedate,
    maintenancetype,
    cost,
    notes,
    vehicleid,
    maintenance_status
)
SELECT 
    (SELECT COALESCE(MAX(m.maintenanceid), 0) FROM public.maintenance1 m) + ROW_NUMBER() OVER (),
    t.maintenancedate,
    t.maintenancetype,
    t.cost::numeric(10,2), -- המרה לפורמט הנדרש ב-maintenance1
    t.description,
    v.vehicleid, -- קישור ל-ID החדש שנוצר בטבלת הרכבים
    'Completed'  -- ערך דיפולטיבי לסטטוס
FROM temp_maintenance_import t
JOIN public.vehicle1 v 
  ON v.licenseplate = regexp_replace(t.platenumber, '[^0-9]', '', 'g')::integer;

